rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isString(v) { return v is string; }
    function isNumber(v) { return v is number; }
    function isBool(v) { return v is bool; }
    function isMap(v) { return v is map; }
    function isTs(v) { return v is timestamp; }

    match /config/app {
      allow read: if true;
      allow write: if false;
    }

    match /config/app/{col}/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if isMe(uid);

      allow create: if isMe(uid)
        && (
          !("uid" in request.resource.data) || request.resource.data.uid == uid
        );

      allow update: if isMe(uid)
        && (
          !("uid" in request.resource.data) || request.resource.data.uid == uid
        )
        ;
    }

    match /users/{uid}/favorites/{docId} {
      allow read: if isMe(uid);

      allow create: if isMe(uid)
        && (
          !("userId" in request.resource.data) || request.resource.data.userId == uid
        )
        && (
          !("uid" in request.resource.data) || request.resource.data.uid == uid
        )

        && (
          !("movieId" in request.resource.data)
          || isNumber(request.resource.data.movieId)
          || isString(request.resource.data.movieId)
        );

      allow update: if isMe(uid)
        && (
          !("userId" in request.resource.data) || request.resource.data.userId == uid
        )
        && (
          !("uid" in request.resource.data) || request.resource.data.uid == uid
        );

      allow delete: if isMe(uid);
    }

    match /users/{uid}/subscription/current {
      allow read, write: if isMe(uid);
    }

    match /users/{uid}/subscriptionHistory/{docId} {
      allow read, write: if isMe(uid);
    }

    match /users/{uid}/payments/{docId} {
      allow read, write: if isMe(uid);
    }

    match /comments/{movieId}/items/{itemId} {
      allow read: if true;

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          !("movieId" in request.resource.data) || request.resource.data.movieId == movieId
        )

        && ("content" in request.resource.data)
        && isString(request.resource.data.content)
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 500;

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /adultFilters/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
